# ──────────────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────
# Skill Service connection (used by the AI Gateway)
# When running with docker-compose, SKILL_URL is overridden
# to http://skill-service:8080 in docker-compose.yml.
# ──────────────────────────────────────────────────────────
SKILL_URL=http://localhost:5000
SKILL_CLIENT_ID=ai-gateway
SKILL_API_KEY=gw-api-key-change-me
SKILL_HMAC_SECRET=gw-hmac-secret-change-me

# ──────────────────────────────────────────────────────────
# AI Gateway port
# ──────────────────────────────────────────────────────────
PORT=3000
