# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before
# running docker-compose or the gateway locally.
# NEVER commit your actual .env to source control.
# ──────────────────────────────────────────────────────────

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_MODEL=gpt-4o-mini

# ── Skill Service ───────────────────────────────────────────
# URL used by the AI Gateway to call the skill service.
# Overridden to http://skill-service:8080 inside docker-compose.
SKILL_URL=http://localhost:5000
SKILL_CLIENT_ID=ai-gateway

# API key and HMAC secret.
# Must match the values in SkillService/appsettings.json (or its env-var overrides).
# Change these to strong random values in production.
SKILL_API_KEY=gw-api-key-change-me
SKILL_HMAC_SECRET=gw-hmac-secret-change-me

# ── AI Gateway port ─────────────────────────────────────────
PORT=3000
